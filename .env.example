# Copie para .env.local e preencha.
# cp .env.example .env.local   (Mac/Linux)
# copy .env.example .env.local (Windows)

DATABASE_URL=
# Após definir DATABASE_URL: `npm run db:migrate` (ou `drizzle/manual_apply_all.sql` no SQL Editor do Neon)
NEON_AUTH_BASE_URL=
# Em `next dev` pode ficar vazio (usa fallback interno). Em produção: gere um segredo ≥32 chars e defina aqui.
NEON_AUTH_COOKIE_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_PAYMENT_LINK=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# SUBSCRIPTION_CHECK_DISABLED=true
